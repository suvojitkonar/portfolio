# Copy to .env.local (gitignored), set values, restart `npm run dev`.
#
# BLOG_ADMIN_PASSWORD — value you type at /admin/blog login.
# BLOG_SESSION_SECRET — min 16 chars; signs the session cookie (use a long random string).
#
# One-liner to generate both:
#   node -e "const c=require('crypto');console.log('BLOG_ADMIN_PASSWORD='+c.randomBytes(18).toString('base64url'));console.log('BLOG_SESSION_SECRET='+c.randomBytes(32).toString('base64url'));"
BLOG_ADMIN_PASSWORD=
BLOG_SESSION_SECRET=

# Projects kanban (shared for all visitors). Use one of:
#
# A) Upstash REST (Vercel Marketplace Redis often exposes these):
#   UPSTASH_REDIS_REST_URL=
#   UPSTASH_REDIS_REST_TOKEN=
#    Optional legacy: KV_REST_API_URL, KV_REST_API_TOKEN
#
# B) TCP connection string (Vercel Redis integration usually sets REDIS_URL):
#   REDIS_URL=redis://default:PASSWORD@host:port
#    Also read: STORAGE_REDIS_URL, storage_REDIS_URL
#
# If both REST and TCP are set, REST is used first. Without any of the above,
# the board still loads but only defaults/localStorage apply.

# Contact page WhatsApp link (digits only: country code + number, e.g. 14155552671).
# NEXT_PUBLIC_WHATSAPP_NUMBER=
